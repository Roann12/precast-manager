# Copy to ".env" and fill in strong secrets for production.
#
# IMPORTANT:
# - Never commit ".env" to source control
# - Use long random values for secrets/passwords

# App environment
ENVIRONMENT=production
ENABLE_DEV_ENDPOINTS=false

# Postgres (used by docker-compose + backend)
POSTGRES_USER=precast
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=precast_manager

# Backend auth (minimum 16 characters; use a long random string in production)
JWT_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_SECRET_AT_LEAST_16_CHARS

# CORS: set to your real public origins in production
# Example:
# BACKEND_CORS_ORIGINS=["https://precastmanager.co.za","https://app.precastmanager.co.za"]
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

